# ShortGen Configuration
# Copy this file to .env and customize

# Paths
SHORTGEN_DATA_DIR=./data
SHORTGEN_OUTPUT_DIR=./output
SHORTGEN_MODELS_DIR=./models

# Whisper settings
SHORTGEN_WHISPER_MODEL=base  # tiny, base, small, medium, large
SHORTGEN_WHISPER_DEVICE=auto  # auto, cpu, cuda

# Ollama LLM settings
SHORTGEN_OLLAMA_BASE_URL=http://localhost:11434
SHORTGEN_OLLAMA_MODEL=gemma4:31b-cloud

# Processing settings
SHORTGEN_MIN_SEGMENT_DURATION=15.0
SHORTGEN_MAX_SEGMENT_DURATION=120.0
SHORTGEN_TARGET_SEGMENTS=5

# Output settings
SHORTGEN_DEFAULT_PLATFORM=youtube_shorts
SHORTGEN_OUTPUT_FPS=30

# API settings
SHORTGEN_API_HOST=0.0.0.0
SHORTGEN_API_PORT=8000

# Performance
SHORTGEN_MAX_CONCURRENT_JOBS=2
SHORTGEN_USE_GPU=true
